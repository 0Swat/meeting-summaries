@using MeetingSummaries.Api.Dto.Responses
@using MeetingSummaries.Api.Models
@inject HttpClient Http

<div class="meeting-calendar">
    <div class="cal-nav d-flex align-items-center justify-content-between mb-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PrevMonth">&#8592;</button>
        <span class="fw-semibold fs-5">@_current.ToString("MMMM yyyy", _pl)</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextMonth">&#8594;</button>
    </div>

    <div class="cal-grid">
        @foreach (var name in _dayNames)
        {
            <div class="cal-cell cal-header">@name</div>
        }

        @foreach (var cell in _cells)
        {
            @if (cell is null)
            {
                <div class="cal-cell cal-empty"></div>
            }
            else
            {
                var date = cell.Value;
                var isToday = date == _today;
                var isSelected = date == SelectedDate;
                var dots = _dots.TryGetValue(date, out var d) ? d : null;

                <div class="cal-cell cal-day @(isToday ? "cal-today" : "") @(isSelected ? "cal-selected" : "") @(dots is not null ? "cal-has-events" : "")"
                     @onclick="() => SelectDate(date)">
                    <span class="cal-day-num">@date.Day</span>
                    @if (dots is not null)
                    {
                        <div class="cal-dots">
                            @foreach (var type in dots)
                            {
                                <span class="cal-dot" style="background:@TypeColor(type)" title="@type"></span>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    <div class="cal-legend mt-2 d-flex flex-wrap gap-2">
        @foreach (var type in Enum.GetValues<MeetingType>())
        {
            <span class="d-flex align-items-center gap-1 small">
                <span class="cal-dot" style="background:@TypeColor(type)"></span>
                @type
            </span>
        }
    </div>
</div>

<style>
    .meeting-calendar {
        max-width: 420px;
    }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 3px;
    }

    .cal-cell {
        min-height: 52px;
        border-radius: 6px;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 3px 2px;
    }

    .cal-header {
        min-height: unset;
        font-size: .75rem;
        font-weight: 600;
        color: #6c757d;
        padding-bottom: 2px;
    }

    .cal-empty {
        background: transparent;
    }

    .cal-day {
        cursor: pointer;
        background: #f8f9fa;
        border: 2px solid transparent;
        transition: background .12s, border-color .12s;
    }

    .cal-day:hover {
        background: #e9ecef;
    }

    .cal-today .cal-day-num {
        font-weight: 700;
        color: #0d6efd;
    }

    .cal-selected {
        border-color: #0d6efd !important;
        background: #e7f1ff !important;
    }

    .cal-day-num {
        font-size: .85rem;
        line-height: 1.4;
    }

    .cal-dots {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2px;
        margin-top: 2px;
    }

    .cal-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    [data-bs-theme="dark"] .cal-day {
        background: #2b3035;
    }

    [data-bs-theme="dark"] .cal-day:hover {
        background: #373d44;
    }

    [data-bs-theme="dark"] .cal-selected {
        background: #1a2c4e !important;
    }
</style>

@code {
    [Parameter] public DateOnly? SelectedDate { get; set; }
    [Parameter] public EventCallback<DateOnly> SelectedDateChanged { get; set; }

    private DateOnly _today = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _current;
    private List<DateOnly?> _cells = new();
    private Dictionary<DateOnly, List<MeetingType>> _dots = new();

    private readonly System.Globalization.CultureInfo _pl =
        System.Globalization.CultureInfo.GetCultureInfo("pl-PL");

    private readonly string[] _dayNames = ["Pn", "Wt", "Śr", "Cz", "Pt", "So", "Nd"];

    protected override async Task OnInitializedAsync()
    {
        _current = new DateOnly(_today.Year, _today.Month, 1);
        BuildCells();
        await LoadDots();
    }

    private void BuildCells()
    {
        _cells.Clear();
        var first = _current;
        // ISO: Monday = 1, Sunday = 7; DayOfWeek: Sunday = 0
        var dow = ((int)first.DayOfWeek + 6) % 7; // 0=Mon … 6=Sun
        for (int i = 0; i < dow; i++) _cells.Add(null);
        var days = DateTime.DaysInMonth(_current.Year, _current.Month);
        for (int d = 1; d <= days; d++) _cells.Add(new DateOnly(_current.Year, _current.Month, d));
    }

    private async Task LoadDots()
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<DayDotsDto>>(
                $"api/meetings/month/{_current.Year}/{_current.Month}") ?? new();
            _dots = list.ToDictionary(x => x.Date, x => x.Types);
        }
        catch { _dots = new(); }
    }

    private async Task PrevMonth()
    {
        _current = _current.AddMonths(-1);
        BuildCells();
        await LoadDots();
    }

    private async Task NextMonth()
    {
        _current = _current.AddMonths(1);
        BuildCells();
        await LoadDots();
    }

    private async Task SelectDate(DateOnly date)
    {
        await SelectedDateChanged.InvokeAsync(date);
    }

    public async Task RefreshDots()
    {
        await LoadDots();
        StateHasChanged();
    }

    private static string TypeColor(MeetingType type) => type switch
    {
        MeetingType.Daily         => "#0d6efd",
        MeetingType.Refinement    => "#fd7e14",
        MeetingType.Retro         => "#dc3545",
        MeetingType.SprintReview  => "#198754",
        MeetingType.SprintPlanning => "#6f42c1",
        _                         => "#adb5bd"
    };
}
